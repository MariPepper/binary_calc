<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Binary Calculator</title>
    <style>
        * {
            box-sizing: border-box;
            font-family: 'Courier New', monospace;
        }
        body {
            background: #1e1e2f;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            padding: 20px;
        }
        .calc {
            background: #2d2d44;
            border-radius: 20px;
            padding: 25px;
            width: 100%;
            max-width: 1000px;
        }
        h1 {
            text-align: center;
            color: #f5f5f5;
            font-size: 1.3rem;
        }
        .inputs {
            display: flex;
            gap: 20px;
            margin: 20px 0;
        }
        .input-group {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        label {
            color: #ccc;
        }
        input {
            background: #1e1e2a;
            border: 1px solid #5a5a7a;
            color: #0f0;
            font-size: 1.3rem;
            padding: 10px;
            border-radius: 8px;
            text-align: center;
            font-family: monospace;
        }
        .ops {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin-bottom: 20px;
        }
        .op-btn {
            background: #3a3a55;
            border: none;
            color: white;
            font-size: 1.2rem;
            padding: 8px 20px;
            border-radius: 40px;
            cursor: pointer;
        }
        .op-btn.active {
            background: #5a7a9a;
        }
        .calc-btn {
            background: #2a7a3a;
            width: 100%;
            padding: 12px;
            font-size: 1.2rem;
            border: none;
            border-radius: 40px;
            color: white;
            cursor: pointer;
            margin: 15px 0;
        }
        .output {
            background: #1a1a2a;
            border-radius: 15px;
            padding: 20px;
        }
        .step {
            background: #252538;
            padding: 6px 12px;
            margin: 4px 0;
            border-radius: 6px;
            color: #ddd;
            font-family: monospace;
            white-space: pre-wrap;
        }
        .result {
            background: #0a2a2a;
            padding: 12px;
            border-radius: 10px;
            margin-top: 15px;
            text-align: center;
            font-size: 1.3rem;
            font-weight: bold;
            color: #0f0;
        }
        .error {
            color: #f66;
            background: #3a1a1a;
            padding: 10px;
        }
    </style>
</head>
<body>
<div class="calc">
    <h1>BINARY CALCULATOR</h1>

    <div class="inputs">
        <div class="input-group">
            <label>Binary A</label>
            <input type="text" id="numA" value="1111">
        </div>
        <div class="input-group">
            <label>Binary B</label>
            <input type="text" id="numB" value="101">
        </div>
    </div>

    <div class="ops">
        <button class="op-btn" data-op="+">+ ADD</button>
        <button class="op-btn" data-op="-">- SUB</button>
        <button class="op-btn" data-op="*">× MUL</button>
    </div>

    <button class="calc-btn" id="calc">CALCULATE</button>

    <div id="output" class="output"></div>
</div>

<script>
    let currentOp = '+';
    document.querySelectorAll('.op-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.op-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            currentOp = btn.getAttribute('data-op');
        });
    });
    document.querySelector('.op-btn[data-op="+"]').classList.add('active');

    function isBinary(str) {
        return /^[01]+$/.test(str);
    }

    // ADDITION
    function addSteps(a, b) {
        let maxLen = Math.max(a.length, b.length);
        let binA = a.padStart(maxLen, '0');
        let binB = b.padStart(maxLen, '0');
        let steps = [];
        
        let resultBits = [];
        let carry = 0;
        let stepLines = [];
        
        for (let i = maxLen - 1; i >= 0; i--) {
            let bitA = parseInt(binA[i]);
            let bitB = parseInt(binB[i]);
            let sum = bitA + bitB + carry;
            let outBit = sum % 2;
            let newCarry = Math.floor(sum / 2);
            resultBits.unshift(outBit);
            
            if (carry === 1) {
                stepLines.push(`${bitA} + ${bitB} + ${carry} = ${outBit} (carry ${newCarry})`);
            } else if (newCarry === 1) {
                stepLines.push(`${bitA} + ${bitB} = ${outBit} (carry ${newCarry})`);
            } else {
                stepLines.push(`${bitA} + ${bitB} = ${outBit}`);
            }
            carry = newCarry;
        }
        
        for (let i = 0; i < stepLines.length; i++) {
            steps.push(stepLines[i]);
        }
        
        if (carry === 1) {
            resultBits.unshift(carry);
            steps.push(`carry final = ${carry}`);
        }
        
        let result = resultBits.join('');
        steps.push(`RESULT = ${result}`);
        return { steps, result };
    }

    // SUBTRACTION - SEM NEGATIVO, com borrow no formato correto
    function subSteps(a, b) {
        let maxLen = Math.max(a.length, b.length);
        let binA = a.padStart(maxLen, '0');
        let binB = b.padStart(maxLen, '0');
        let steps = [];
        
        let borrow = 0;
        let resultBits = [];
        let stepLines = [];
        
        for (let i = maxLen - 1; i >= 0; i--) {
            let bitA = parseInt(binA[i]);
            let bitB = parseInt(binB[i]);
            let diff = bitA - bitB - borrow;
            
            if (diff >= 0) {
                resultBits.unshift(diff);
                if (borrow === 1) {
                    stepLines.push(`${bitA} - ${bitB} - ${borrow} = ${diff}`);
                } else {
                    stepLines.push(`${bitA} - ${bitB} = ${diff}`);
                }
                borrow = 0;
            } else {
                diff += 2;
                resultBits.unshift(diff);
                if (borrow === 1) {
                    stepLines.push(`${bitA} - ${bitB} - ${borrow} = ${diff} (borrow 1)`);
                } else {
                    stepLines.push(`${bitA} - ${bitB} = ${diff} (borrow 1)`);
                }
                borrow = 1;
            }
        }
        
        for (let i = 0; i < stepLines.length; i++) {
            steps.push(stepLines[i]);
        }
        
        let result = resultBits.join('');
        steps.push(`RESULT = ${result}`);
        return { steps, result };
    }

    // MULTIPLICATION
    function mulSteps(a, b) {
        let steps = [];
        
        let revB = b.split('').reverse();
        let partials = [];
        
        for (let i = 0; i < revB.length; i++) {
            if (revB[i] === '0') {
                let p = '0'.repeat(a.length);
                steps.push(`${a} × ${revB[i]} = ${p}`);
                partials.push(p + '0'.repeat(i));
            } else {
                steps.push(`${a} × ${revB[i]} = ${a}`);
                partials.push(a + '0'.repeat(i));
            }
        }
        
        steps.push("");
        
        let maxLen = Math.max(a.length, b.length);
        let width = maxLen + 2;
        steps.push(`${' '.repeat(width - a.length)}${a}`);
        steps.push(`×${' '.repeat(width - b.length - 1)}${b}`);
        steps.push(`-`.repeat(width + 2));
        
        let maxPartialLen = Math.max(...partials.map(p => p.length), a.length + b.length);
        for (let i = 0; i < partials.length; i++) {
            steps.push(`${' '.repeat(maxPartialLen - partials[i].length + 1)}${partials[i]}`);
        }
        steps.push(`-`.repeat(maxPartialLen + 2));
        
        let result = (parseInt(a, 2) * parseInt(b, 2)).toString(2);
        steps.push(`${' '.repeat(maxPartialLen - result.length + 1)}${result}`);
        steps.push("");
        steps.push(`RESULT = ${result}`);
        
        return { steps, result };
    }

    document.getElementById('calc').addEventListener('click', () => {
        let numA = document.getElementById('numA').value.trim();
        let numB = document.getElementById('numB').value.trim();
        let out = document.getElementById('output');
        
        if (!isBinary(numA) || !isBinary(numB)) {
            out.innerHTML = `<div class="error">ERROR: Only 0 and 1 allowed</div>`;
            return;
        }
        
        let res;
        try {
            if (currentOp === '+') res = addSteps(numA, numB);
            else if (currentOp === '-') res = subSteps(numA, numB);
            else res = mulSteps(numA, numB);
        } catch(e) {
            out.innerHTML = `<div class="error">Error: ${e.message}</div>`;
            return;
        }
        
        let html = '';
        for (let s of res.steps) {
            html += `<div class="step">${s}</div>`;
        }
        html += `<div class="result">FINAL: ${res.result}</div>`;
        out.innerHTML = html;
    });
</script>
</body>
</html>
